digraph ER {

    graph [
        label       = "习题推荐系统 — 数据库 ER 图"
        labelloc    = t
        fontname    = "Microsoft YaHei"
        fontsize    = 18
        rankdir     = LR
        splines     = ortho
        nodesep     = 0.8
        ranksep     = 2.0
        bgcolor     = white
    ]
    node  [shape=none fontname="Microsoft YaHei" fontsize=11]
    edge  [fontname="Microsoft YaHei" fontsize=10 color="#555555"]

    // ─────────────────────────────────────────────────────────────
    // 实体定义（HTML 表格标签）
    // ─────────────────────────────────────────────────────────────

    sys_user [label=<
        <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0">
        <TR><TD COLSPAN="3" BGCOLOR="#1565C0"><FONT COLOR="white"><B> sys_user （用户表）</B></FONT></TD></TR>
        <TR><TD BGCOLOR="#BBDEFB"><B>字段</B></TD><TD BGCOLOR="#BBDEFB"><B>类型</B></TD><TD BGCOLOR="#BBDEFB"><B>说明</B></TD></TR>
        <TR><TD PORT="id" ALIGN="LEFT">🔑 id</TD><TD ALIGN="LEFT">BIGINT</TD><TD ALIGN="LEFT">主键</TD></TR>
        <TR><TD ALIGN="LEFT">username</TD><TD ALIGN="LEFT">VARCHAR(50)</TD><TD ALIGN="LEFT">用户名 UNIQUE</TD></TR>
        <TR><TD ALIGN="LEFT">password</TD><TD ALIGN="LEFT">VARCHAR(255)</TD><TD ALIGN="LEFT">BCrypt密码</TD></TR>
        <TR><TD ALIGN="LEFT">real_name</TD><TD ALIGN="LEFT">VARCHAR(50)</TD><TD ALIGN="LEFT">真实姓名</TD></TR>
        <TR><TD ALIGN="LEFT">email</TD><TD ALIGN="LEFT">VARCHAR(100)</TD><TD ALIGN="LEFT">邮箱</TD></TR>
        <TR><TD ALIGN="LEFT">role</TD><TD ALIGN="LEFT">ENUM</TD><TD ALIGN="LEFT">STUDENT/TEACHER/ADMIN</TD></TR>
        <TR><TD ALIGN="LEFT">status</TD><TD ALIGN="LEFT">TINYINT</TD><TD ALIGN="LEFT">1正常/0禁用</TD></TR>
        <TR><TD ALIGN="LEFT">created_at</TD><TD ALIGN="LEFT">DATETIME</TD><TD ALIGN="LEFT">创建时间</TD></TR>
        </TABLE>
    >]

    course [label=<
        <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0">
        <TR><TD COLSPAN="3" BGCOLOR="#1B5E20"><FONT COLOR="white"><B> course （课程表）</B></FONT></TD></TR>
        <TR><TD BGCOLOR="#C8E6C9"><B>字段</B></TD><TD BGCOLOR="#C8E6C9"><B>类型</B></TD><TD BGCOLOR="#C8E6C9"><B>说明</B></TD></TR>
        <TR><TD PORT="id" ALIGN="LEFT">🔑 id</TD><TD ALIGN="LEFT">BIGINT</TD><TD ALIGN="LEFT">主键</TD></TR>
        <TR><TD ALIGN="LEFT">name</TD><TD ALIGN="LEFT">VARCHAR(100)</TD><TD ALIGN="LEFT">课程名称</TD></TR>
        <TR><TD ALIGN="LEFT">description</TD><TD ALIGN="LEFT">TEXT</TD><TD ALIGN="LEFT">课程简介</TD></TR>
        <TR><TD PORT="teacher_id" ALIGN="LEFT">🔗 teacher_id</TD><TD ALIGN="LEFT">BIGINT</TD><TD ALIGN="LEFT">FK→sys_user</TD></TR>
        <TR><TD ALIGN="LEFT">status</TD><TD ALIGN="LEFT">TINYINT</TD><TD ALIGN="LEFT">1上线/0下线</TD></TR>
        </TABLE>
    >]

    knowledge_point [label=<
        <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0">
        <TR><TD COLSPAN="3" BGCOLOR="#4A148C"><FONT COLOR="white"><B> knowledge_point （知识点表）</B></FONT></TD></TR>
        <TR><TD BGCOLOR="#E1BEE7"><B>字段</B></TD><TD BGCOLOR="#E1BEE7"><B>类型</B></TD><TD BGCOLOR="#E1BEE7"><B>说明</B></TD></TR>
        <TR><TD PORT="id" ALIGN="LEFT">🔑 id</TD><TD ALIGN="LEFT">BIGINT</TD><TD ALIGN="LEFT">主键</TD></TR>
        <TR><TD ALIGN="LEFT">kc_name</TD><TD ALIGN="LEFT">VARCHAR(50)</TD><TD ALIGN="LEFT">模型内部名 kc0…</TD></TR>
        <TR><TD ALIGN="LEFT">name</TD><TD ALIGN="LEFT">VARCHAR(100)</TD><TD ALIGN="LEFT">可读名称</TD></TR>
        <TR><TD PORT="course_id" ALIGN="LEFT">🔗 course_id</TD><TD ALIGN="LEFT">BIGINT</TD><TD ALIGN="LEFT">FK→course</TD></TR>
        <TR><TD ALIGN="LEFT">difficulty</TD><TD ALIGN="LEFT">TINYINT</TD><TD ALIGN="LEFT">难度1~5</TD></TR>
        <TR><TD ALIGN="LEFT">neo4j_node_id</TD><TD ALIGN="LEFT">VARCHAR(100)</TD><TD ALIGN="LEFT">Neo4j节点ID</TD></TR>
        </TABLE>
    >]

    exercise [label=<
        <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0">
        <TR><TD COLSPAN="3" BGCOLOR="#E65100"><FONT COLOR="white"><B> exercise （习题表）</B></FONT></TD></TR>
        <TR><TD BGCOLOR="#FFE0B2"><B>字段</B></TD><TD BGCOLOR="#FFE0B2"><B>类型</B></TD><TD BGCOLOR="#FFE0B2"><B>说明</B></TD></TR>
        <TR><TD PORT="id" ALIGN="LEFT">🔑 id</TD><TD ALIGN="LEFT">BIGINT</TD><TD ALIGN="LEFT">主键</TD></TR>
        <TR><TD ALIGN="LEFT">ex_name</TD><TD ALIGN="LEFT">VARCHAR(50)</TD><TD ALIGN="LEFT">模型内部名 ex0…</TD></TR>
        <TR><TD ALIGN="LEFT">content</TD><TD ALIGN="LEFT">TEXT</TD><TD ALIGN="LEFT">题目正文(Markdown)</TD></TR>
        <TR><TD ALIGN="LEFT">type</TD><TD ALIGN="LEFT">ENUM</TD><TD ALIGN="LEFT">题型</TD></TR>
        <TR><TD ALIGN="LEFT">options</TD><TD ALIGN="LEFT">JSON</TD><TD ALIGN="LEFT">选项</TD></TR>
        <TR><TD ALIGN="LEFT">answer</TD><TD ALIGN="LEFT">VARCHAR(500)</TD><TD ALIGN="LEFT">标准答案</TD></TR>
        <TR><TD ALIGN="LEFT">difficulty</TD><TD ALIGN="LEFT">TINYINT</TD><TD ALIGN="LEFT">难度1~5</TD></TR>
        <TR><TD PORT="course_id" ALIGN="LEFT">🔗 course_id</TD><TD ALIGN="LEFT">BIGINT</TD><TD ALIGN="LEFT">FK→course</TD></TR>
        <TR><TD PORT="created_by" ALIGN="LEFT">🔗 created_by</TD><TD ALIGN="LEFT">BIGINT</TD><TD ALIGN="LEFT">FK→sys_user</TD></TR>
        <TR><TD ALIGN="LEFT">neo4j_node_id</TD><TD ALIGN="LEFT">VARCHAR(100)</TD><TD ALIGN="LEFT">Neo4j节点ID</TD></TR>
        </TABLE>
    >]

    exercise_kp_rel [label=<
        <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0">
        <TR><TD COLSPAN="3" BGCOLOR="#37474F"><FONT COLOR="white"><B> exercise_kp_rel （习题-知识点关联）</B></FONT></TD></TR>
        <TR><TD BGCOLOR="#ECEFF1"><B>字段</B></TD><TD BGCOLOR="#ECEFF1"><B>类型</B></TD><TD BGCOLOR="#ECEFF1"><B>说明</B></TD></TR>
        <TR><TD PORT="id" ALIGN="LEFT">🔑 id</TD><TD ALIGN="LEFT">BIGINT</TD><TD ALIGN="LEFT">主键</TD></TR>
        <TR><TD PORT="exercise_id" ALIGN="LEFT">🔗 exercise_id</TD><TD ALIGN="LEFT">BIGINT</TD><TD ALIGN="LEFT">FK→exercise</TD></TR>
        <TR><TD PORT="kp_id" ALIGN="LEFT">🔗 knowledge_point_id</TD><TD ALIGN="LEFT">BIGINT</TD><TD ALIGN="LEFT">FK→knowledge_point</TD></TR>
        </TABLE>
    >]

    answer_record [label=<
        <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0">
        <TR><TD COLSPAN="3" BGCOLOR="#AD1457"><FONT COLOR="white"><B> answer_record （答题记录表）</B></FONT></TD></TR>
        <TR><TD BGCOLOR="#FCE4EC"><B>字段</B></TD><TD BGCOLOR="#FCE4EC"><B>类型</B></TD><TD BGCOLOR="#FCE4EC"><B>说明</B></TD></TR>
        <TR><TD PORT="id" ALIGN="LEFT">🔑 id</TD><TD ALIGN="LEFT">BIGINT</TD><TD ALIGN="LEFT">主键</TD></TR>
        <TR><TD PORT="user_id" ALIGN="LEFT">🔗 user_id</TD><TD ALIGN="LEFT">BIGINT</TD><TD ALIGN="LEFT">FK→sys_user</TD></TR>
        <TR><TD PORT="exercise_id" ALIGN="LEFT">🔗 exercise_id</TD><TD ALIGN="LEFT">BIGINT</TD><TD ALIGN="LEFT">FK→exercise</TD></TR>
        <TR><TD ALIGN="LEFT">user_answer</TD><TD ALIGN="LEFT">TEXT</TD><TD ALIGN="LEFT">作答内容</TD></TR>
        <TR><TD ALIGN="LEFT">is_correct</TD><TD ALIGN="LEFT">TINYINT</TD><TD ALIGN="LEFT">1正确/0错误/NULL待批</TD></TR>
        <TR><TD ALIGN="LEFT">score</TD><TD ALIGN="LEFT">DECIMAL(5,2)</TD><TD ALIGN="LEFT">得分</TD></TR>
        <TR><TD ALIGN="LEFT">grade_type</TD><TD ALIGN="LEFT">ENUM</TD><TD ALIGN="LEFT">AUTO/MANUAL</TD></TR>
        <TR><TD ALIGN="LEFT">grade_status</TD><TD ALIGN="LEFT">ENUM</TD><TD ALIGN="LEFT">GRADED/PENDING</TD></TR>
        <TR><TD ALIGN="LEFT">teacher_comment</TD><TD ALIGN="LEFT">TEXT</TD><TD ALIGN="LEFT">教师评语</TD></TR>
        <TR><TD PORT="graded_by" ALIGN="LEFT">🔗 graded_by</TD><TD ALIGN="LEFT">BIGINT</TD><TD ALIGN="LEFT">FK→sys_user</TD></TR>
        <TR><TD ALIGN="LEFT">submitted_at</TD><TD ALIGN="LEFT">DATETIME</TD><TD ALIGN="LEFT">提交时间</TD></TR>
        </TABLE>
    >]

    recommendation_record [label=<
        <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0">
        <TR><TD COLSPAN="3" BGCOLOR="#00695C"><FONT COLOR="white"><B> recommendation_record （推荐记录）</B></FONT></TD></TR>
        <TR><TD BGCOLOR="#E0F2F1"><B>字段</B></TD><TD BGCOLOR="#E0F2F1"><B>类型</B></TD><TD BGCOLOR="#E0F2F1"><B>说明</B></TD></TR>
        <TR><TD PORT="id" ALIGN="LEFT">🔑 id</TD><TD ALIGN="LEFT">BIGINT</TD><TD ALIGN="LEFT">主键</TD></TR>
        <TR><TD PORT="user_id" ALIGN="LEFT">🔗 user_id</TD><TD ALIGN="LEFT">BIGINT</TD><TD ALIGN="LEFT">FK→sys_user</TD></TR>
        <TR><TD ALIGN="LEFT">trigger_type</TD><TD ALIGN="LEFT">ENUM</TD><TD ALIGN="LEFT">AUTO/MANUAL</TD></TR>
        <TR><TD ALIGN="LEFT">top_n</TD><TD ALIGN="LEFT">INT</TD><TD ALIGN="LEFT">推荐数量</TD></TR>
        <TR><TD ALIGN="LEFT">created_at</TD><TD ALIGN="LEFT">DATETIME</TD><TD ALIGN="LEFT">推荐时间</TD></TR>
        </TABLE>
    >]

    rec_exercise_item [label=<
        <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0">
        <TR><TD COLSPAN="3" BGCOLOR="#00695C"><FONT COLOR="white"><B> rec_exercise_item （推荐明细）</B></FONT></TD></TR>
        <TR><TD BGCOLOR="#E0F2F1"><B>字段</B></TD><TD BGCOLOR="#E0F2F1"><B>类型</B></TD><TD BGCOLOR="#E0F2F1"><B>说明</B></TD></TR>
        <TR><TD PORT="id" ALIGN="LEFT">🔑 id</TD><TD ALIGN="LEFT">BIGINT</TD><TD ALIGN="LEFT">主键</TD></TR>
        <TR><TD PORT="record_id" ALIGN="LEFT">🔗 record_id</TD><TD ALIGN="LEFT">BIGINT</TD><TD ALIGN="LEFT">FK→recommendation_record</TD></TR>
        <TR><TD PORT="exercise_id" ALIGN="LEFT">🔗 exercise_id</TD><TD ALIGN="LEFT">BIGINT</TD><TD ALIGN="LEFT">FK→exercise</TD></TR>
        <TR><TD ALIGN="LEFT">score</TD><TD ALIGN="LEFT">DECIMAL(10,4)</TD><TD ALIGN="LEFT">模型推荐评分</TD></TR>
        <TR><TD ALIGN="LEFT">rank_order</TD><TD ALIGN="LEFT">INT</TD><TD ALIGN="LEFT">排名序号</TD></TR>
        </TABLE>
    >]

    user_kc_state [label=<
        <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0">
        <TR><TD COLSPAN="3" BGCOLOR="#F57F17"><FONT COLOR="white"><B> user_kc_state （知识点状态缓存）</B></FONT></TD></TR>
        <TR><TD BGCOLOR="#FFF9C4"><B>字段</B></TD><TD BGCOLOR="#FFF9C4"><B>类型</B></TD><TD BGCOLOR="#FFF9C4"><B>说明</B></TD></TR>
        <TR><TD PORT="id" ALIGN="LEFT">🔑 id</TD><TD ALIGN="LEFT">BIGINT</TD><TD ALIGN="LEFT">主键</TD></TR>
        <TR><TD PORT="user_id" ALIGN="LEFT">🔗 user_id</TD><TD ALIGN="LEFT">BIGINT</TD><TD ALIGN="LEFT">FK→sys_user</TD></TR>
        <TR><TD PORT="kp_id" ALIGN="LEFT">🔗 knowledge_point_id</TD><TD ALIGN="LEFT">BIGINT</TD><TD ALIGN="LEFT">FK→knowledge_point</TD></TR>
        <TR><TD ALIGN="LEFT">mastery_level</TD><TD ALIGN="LEFT">DECIMAL(5,4)</TD><TD ALIGN="LEFT">掌握度 mlkc 0~1</TD></TR>
        <TR><TD ALIGN="LEFT">appear_prob</TD><TD ALIGN="LEFT">DECIMAL(5,4)</TD><TD ALIGN="LEFT">出现概率 pkc 0~1</TD></TR>
        <TR><TD ALIGN="LEFT">updated_at</TD><TD ALIGN="LEFT">DATETIME</TD><TD ALIGN="LEFT">更新时间</TD></TR>
        </TABLE>
    >]

    user_exercise_forget [label=<
        <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0">
        <TR><TD COLSPAN="3" BGCOLOR="#F57F17"><FONT COLOR="white"><B> user_exercise_forget （遗忘率缓存）</B></FONT></TD></TR>
        <TR><TD BGCOLOR="#FFF9C4"><B>字段</B></TD><TD BGCOLOR="#FFF9C4"><B>类型</B></TD><TD BGCOLOR="#FFF9C4"><B>说明</B></TD></TR>
        <TR><TD PORT="id" ALIGN="LEFT">🔑 id</TD><TD ALIGN="LEFT">BIGINT</TD><TD ALIGN="LEFT">主键</TD></TR>
        <TR><TD PORT="user_id" ALIGN="LEFT">🔗 user_id</TD><TD ALIGN="LEFT">BIGINT</TD><TD ALIGN="LEFT">FK→sys_user</TD></TR>
        <TR><TD PORT="exercise_id" ALIGN="LEFT">🔗 exercise_id</TD><TD ALIGN="LEFT">BIGINT</TD><TD ALIGN="LEFT">FK→exercise</TD></TR>
        <TR><TD ALIGN="LEFT">forget_rate</TD><TD ALIGN="LEFT">DECIMAL(5,4)</TD><TD ALIGN="LEFT">遗忘率 exfr 0~1</TD></TR>
        <TR><TD ALIGN="LEFT">updated_at</TD><TD ALIGN="LEFT">DATETIME</TD><TD ALIGN="LEFT">更新时间</TD></TR>
        </TABLE>
    >]

    // ─────────────────────────────────────────────────────────────
    // 关系连线（标注基数）
    // ─────────────────────────────────────────────────────────────

    // sys_user → course（教师创建课程 1:N）
    sys_user:id -> course:teacher_id         [label="1:N  创建" arrowhead=crow arrowtail=tee dir=both]

    // sys_user → exercise（教师创建习题 1:N）
    sys_user:id -> exercise:created_by       [label="1:N  创建" arrowhead=crow arrowtail=tee dir=both]

    // course → knowledge_point（1:N）
    course:id -> knowledge_point:course_id   [label="1:N  包含" arrowhead=crow arrowtail=tee dir=both]

    // course → exercise（1:N）
    course:id -> exercise:course_id          [label="1:N  归属" arrowhead=crow arrowtail=tee dir=both]

    // exercise ↔ knowledge_point（M:N 通过关联表）
    exercise:id -> exercise_kp_rel:exercise_id      [label="1:N" arrowhead=crow arrowtail=tee dir=both]
    knowledge_point:id -> exercise_kp_rel:kp_id     [label="1:N" arrowhead=crow arrowtail=tee dir=both]

    // sys_user → answer_record（1:N）
    sys_user:id -> answer_record:user_id     [label="1:N  答题" arrowhead=crow arrowtail=tee dir=both]

    // exercise → answer_record（1:N）
    exercise:id -> answer_record:exercise_id [label="1:N" arrowhead=crow arrowtail=tee dir=both]

    // sys_user → answer_record（批改 1:N）
    sys_user:id -> answer_record:graded_by   [label="1:N  批改" arrowhead=crow arrowtail=tee dir=both style=dashed]

    // sys_user → recommendation_record（1:N）
    sys_user:id -> recommendation_record:user_id    [label="1:N  推荐" arrowhead=crow arrowtail=tee dir=both]

    // recommendation_record → rec_exercise_item（1:N）
    recommendation_record:id -> rec_exercise_item:record_id  [label="1:N" arrowhead=crow arrowtail=tee dir=both]

    // exercise → rec_exercise_item（1:N）
    exercise:id -> rec_exercise_item:exercise_id    [label="1:N" arrowhead=crow arrowtail=tee dir=both]

    // sys_user → user_kc_state（1:N）
    sys_user:id -> user_kc_state:user_id     [label="1:N" arrowhead=crow arrowtail=tee dir=both]

    // knowledge_point → user_kc_state（1:N）
    knowledge_point:id -> user_kc_state:kp_id [label="1:N" arrowhead=crow arrowtail=tee dir=both]

    // sys_user → user_exercise_forget（1:N）
    sys_user:id -> user_exercise_forget:user_id    [label="1:N" arrowhead=crow arrowtail=tee dir=both]

    // exercise → user_exercise_forget（1:N）
    exercise:id -> user_exercise_forget:exercise_id [label="1:N" arrowhead=crow arrowtail=tee dir=both]
}
