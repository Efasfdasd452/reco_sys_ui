digraph Architecture {

    graph [
        label       = "习题推荐系统 — 整体架构图"
        labelloc    = t
        fontname    = "Microsoft YaHei"
        fontsize    = 18
        rankdir     = TB
        splines     = ortho
        nodesep     = 0.8
        ranksep     = 1.2
        bgcolor     = "#FAFAFA"
        pad         = 0.5
    ]
    node [fontname="Microsoft YaHei" fontsize=12]
    edge [fontname="Microsoft YaHei" fontsize=10]

    // ─────────────────────────────────────────────────────────────
    // 前端层
    // ─────────────────────────────────────────────────────────────
    subgraph cluster_frontend {
        label     = "前端层 (React)"
        style     = filled
        bgcolor   = "#E3F2FD"
        color     = "#1565C0"
        penwidth  = 2
        fontsize  = 13
        fontname  = "Microsoft YaHei"

        node [shape=box style="filled,rounded" fillcolor="#BBDEFB" color="#1565C0" penwidth=1.5]

        fe_auth   [label="登录 / 注册页"]
        fe_home   [label="学生主页\n（推荐习题展示）"]
        fe_ex     [label="习题浏览 / 作答页"]
        fe_state  [label="学习状态\n（知识点掌握度）"]
        fe_hist   [label="答题记录页"]
        fe_teacher [label="教师后台\n（课程/习题/批改）"]
        fe_admin  [label="管理员后台\n（用户管理）"]
    }

    // ─────────────────────────────────────────────────────────────
    // 网关 / 安全层
    // ─────────────────────────────────────────────────────────────
    subgraph cluster_gateway {
        label     = "安全层"
        style     = filled
        bgcolor   = "#FCE4EC"
        color     = "#AD1457"
        penwidth  = 2
        fontsize  = 13
        fontname  = "Microsoft YaHei"

        node [shape=box style="filled,rounded" fillcolor="#F8BBD0" color="#AD1457" penwidth=1.5]

        gw_jwt    [label="JWT Filter\n（Token 校验）"]
        gw_rbac   [label="RBAC\n（角色权限控制）"]
        gw_cors   [label="CORS\n（跨域配置）"]
    }

    // ─────────────────────────────────────────────────────────────
    // 后端业务层（Spring Boot）
    // ─────────────────────────────────────────────────────────────
    subgraph cluster_backend {
        label     = "后端业务层 (Spring Boot :8888)"
        style     = filled
        bgcolor   = "#F3E5F5"
        color     = "#6A1B9A"
        penwidth  = 2
        fontsize  = 13
        fontname  = "Microsoft YaHei"

        node [shape=box style="filled,rounded" fillcolor="#CE93D8" color="#4A148C" penwidth=1.5]

        be_auth    [label="AuthController\n注册/登录/Token"]
        be_user    [label="UserController\n用户信息管理"]
        be_course  [label="CourseController\n课程管理"]
        be_know    [label="KnowledgeController\n知识图谱 CRUD"]
        be_ex      [label="ExerciseController\n习题管理 + 上传"]
        be_learn   [label="LearningController\n答题提交"]
        be_assess  [label="AssessmentController\n学习状态查询"]
        be_rec     [label="RecommendController\n推荐（自动+手动）"]
        be_grade   [label="GradeController\n教师批改问答题"]
        be_file    [label="FileController\n图片上传/访问"]
        be_stat    [label="StatController\n统计分析"]
    }

    // ─────────────────────────────────────────────────────────────
    // 数据层
    // ─────────────────────────────────────────────────────────────
    subgraph cluster_data {
        label     = "数据层"
        style     = filled
        bgcolor   = "#E8F5E9"
        color     = "#1B5E20"
        penwidth  = 2
        fontsize  = 13
        fontname  = "Microsoft YaHei"

        node [shape=cylinder style=filled penwidth=1.5]

        db_mysql [label="MySQL 8.0\n业务数据库" fillcolor="#A5D6A7" color="#2E7D32"]
        db_neo4j [label="Neo4j 5\n知识图谱数据库" fillcolor="#C8E6C9" color="#2E7D32"]
        db_file  [label="本地文件存储\n/uploads/" shape=box style="filled,rounded" fillcolor="#DCEDC8" color="#558B2F"]
    }

    // ─────────────────────────────────────────────────────────────
    // 外部服务层
    // ─────────────────────────────────────────────────────────────
    subgraph cluster_external {
        label     = "外部服务层"
        style     = filled
        bgcolor   = "#FFF8E1"
        color     = "#F57F17"
        penwidth  = 2
        fontsize  = 13
        fontname  = "Microsoft YaHei"

        node [shape=box style="filled,rounded" penwidth=1.5]

        ext_py [label="Python FastAPI :8000\nKG4Ex 推荐算法服务\n(TransE 知识图谱嵌入)" fillcolor="#FFE082" color="#F57F17"]
    }

    // ─────────────────────────────────────────────────────────────
    // 连接关系
    // ─────────────────────────────────────────────────────────────

    // 前端 → 安全层
    edge [color="#1565C0" penwidth=1.5 label="HTTPS\nREST API"]
    fe_auth    -> gw_cors
    fe_home    -> gw_cors
    fe_ex      -> gw_cors
    fe_state   -> gw_cors
    fe_hist    -> gw_cors
    fe_teacher -> gw_cors
    fe_admin   -> gw_cors

    // 安全层内部
    edge [color="#AD1457" penwidth=1.5 label="" arrowhead=vee]
    gw_cors -> gw_jwt -> gw_rbac

    // 安全层 → 后端控制器
    edge [color="#6A1B9A" penwidth=1.5 label=""]
    gw_rbac -> be_auth
    gw_rbac -> be_user
    gw_rbac -> be_course
    gw_rbac -> be_know
    gw_rbac -> be_ex
    gw_rbac -> be_learn
    gw_rbac -> be_assess
    gw_rbac -> be_rec
    gw_rbac -> be_grade
    gw_rbac -> be_file
    gw_rbac -> be_stat

    // 后端 → MySQL
    edge [color="#2E7D32" penwidth=1.5 label="JPA/JDBC"]
    be_auth   -> db_mysql
    be_user   -> db_mysql
    be_course -> db_mysql
    be_ex     -> db_mysql
    be_learn  -> db_mysql
    be_assess -> db_mysql
    be_rec    -> db_mysql
    be_grade  -> db_mysql
    be_stat   -> db_mysql

    // 后端 → Neo4j
    edge [color="#388E3C" penwidth=1.5 label="Spring Data\nNeo4j"]
    be_know -> db_neo4j
    be_rec  -> db_neo4j
    be_stat -> db_neo4j

    // 后端 → 文件存储
    edge [color="#558B2F" penwidth=1.5 label="本地IO"]
    be_file -> db_file
    be_ex   -> db_file

    // 后端 → Python 推荐服务
    edge [color="#F57F17" penwidth=2 label="HTTP POST\nX-API-Key" style=dashed]
    be_rec -> ext_py
}
